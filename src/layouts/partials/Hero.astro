---
import { Image } from "astro:assets";

import Container from "@atoms/Container.astro";

import PHOTO_SQUARE from "@assets/images/hero.square.webp";
import PHOTO_LONG from "@assets/images/hero.long.webp";
import LOGO_LEAF from "@assets/images/logo.partial.leaf.svg";

import * as HERO from "@assets/index.hero.md";
---

<Container direction="col" background={"dark"} spacing={"medium"}>
    <div class="w-full h-auto z-20">
        <Image
            class="sm:hidden px-4 pt-2 pb-0"
            src={PHOTO_SQUARE}
            alt="EVAS: Ecological Validation of Artifical Simulacra ::. Research Cooperative"
        />
        <Image
            class="hidden sm:block pt-4"
            src={PHOTO_LONG}
            alt="EVAS: Ecological Validation of Artifical Simulacra ::. Research Cooperative"
        />
    </div>
    <Image
        class="absolute z-10 right-0 bottom-0"
        src={LOGO_LEAF}
        alt="leaf-decotator-image"
    />
    <div class="z-20">
        <h1 class="text-3xl font-serif text-eggwhite mt-4 mb-0">
            {HERO.frontmatter.title}
        </h1>
        <span class="text-eggwhite font-thin tracking-wide"
            >{HERO.frontmatter.subtitle}</span
        >
    </div>
</Container>
