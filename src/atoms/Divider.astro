---
import { Icon } from "astro-icon/components";

interface Props {
    repetitions?: number;
    size?: number;
    gap?: number;
}

const { repetitions = 5, size = 5, gap = 4 } = Astro.props;
---

<div class:list={[`gap-${gap}`, "my-2 flex justify-center contents-center"]}>
    {
        Array.from({ length: repetitions }).map((_content, index) => (
            <Icon
                class="text-figred"
                class:list={[
                    `text-${size}xl`,
                    `data-[pos=${index - Math.floor(repetitions / 2)}]`,
                ]}
                name="pixel:ellipses-horizontal"
            />
        ))
    }
</div>
